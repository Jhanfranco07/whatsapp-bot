# Base de datos
# DB_MODE=local usa PostgreSQL local (Docker recomendado).
# DB_MODE=cloud usa Supabase o cualquier PostgreSQL remoto mediante DATABASE_URL.
DB_MODE=local
APP_ENV=development
DATABASE_URL=postgresql+psycopg2://usil:usil@localhost:5432/usil_db
POSTGRES_USER=usil
POSTGRES_PASSWORD=cambia-esta-clave-postgres
POSTGRES_DB=usil_db

WHATSAPP_PROVIDER=bridge
WHATSAPP_DRY_RUN=true
WHATSAPP_WAIT_TIME=20
WHATSAPP_CLOSE_TIME=3
BRIDGE_API_URL=http://127.0.0.1:8000
BRIDGE_SEND_URL=http://127.0.0.1:3001/send
BRIDGE_SEND_TIMEOUT=60
BRIDGE_OUTBOUND_HOST=127.0.0.1
BRIDGE_OUTBOUND_PORT=3001
BRIDGE_HEADLESS=true
BRIDGE_MESSAGE_DEBOUNCE_SECONDS=3
INBOUND_API_KEY=cambia-esta-clave-local
ADMIN_API_KEY=cambia-esta-clave-admin
RATE_LIMIT_MESSAGES=6
RATE_LIMIT_WINDOW_SECONDS=60
CAMPAIGN_MINIMUM_GAP_SECONDS=60

PORTAL_OFICIAL_URL=https://www.usil.edu.pe/

APP_ENV=development
LOG_LEVEL=INFO
