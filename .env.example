DATABASE_URL=postgresql+psycopg2://usuario:contraseña@host:5432/base_de_datos?sslmode=require
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=orientador_usil
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

WHATSAPP_PROVIDER=bridge
WHATSAPP_DRY_RUN=true
WHATSAPP_WAIT_TIME=20
WHATSAPP_CLOSE_TIME=3
BRIDGE_API_URL=http://127.0.0.1:8000
BRIDGE_SEND_URL=http://127.0.0.1:3001/send
BRIDGE_SEND_TIMEOUT=60
BRIDGE_OUTBOUND_HOST=127.0.0.1
BRIDGE_OUTBOUND_PORT=3001
BRIDGE_HEADLESS=false
INBOUND_API_KEY=cambia-esta-clave-local

PORTAL_OFICIAL_URL=https://www.usil.edu.pe/

LLM_PROVIDER=ollama
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:0.8b
OLLAMA_THINK=false
OLLAMA_TEMPERATURE=0.2
OLLAMA_MAX_TOKENS=400
OLLAMA_TIMEOUT=120

APP_ENV=development
LOG_LEVEL=INFO
